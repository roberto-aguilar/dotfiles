#!/bin/bash

# `-e` Exit on error.
# `-u` Trait unset variables as an error.
set -eu

# Determine the dotfiles directory.
DOTFILES_DIRECTORY="$(git rev-parse --show-toplevel)"

# Install Laravel devevelopment environment.
~/.local/share/omarchy/bin/omarchy-install-dev-env laravel

# Optimize resolution for my monitors.
sed -i \
  -e 's/^env = GDK_SCALE,2/# &/' \
  -e 's/^monitor=,preferred,auto,auto/# &/' \
  -e 's/^# env = GDK_SCALE,1$/env = GDK_SCALE,1/' \
  -e 's/^# monitor=,preferred,auto,1$/monitor=,preferred,auto,1/' \
  "${HOME}/.config/hypr/monitors.conf"

# Allow to toggle between keyboard layouts.
sed -i \
  -e 's/^.*kb_layout.*/  kb_layout = us,es/' \
  -e 's/^\(.*kb_options = compose:caps\).*/\1,grp:alts_toggle/' \
  "${HOME}/.config/hypr/input.conf"

# Show the active keyboard layout in waybar.
WAYBAR_CONFIG="${HOME}/.config/waybar/config.jsonc"
if ! jq -e '."modules-right" | index("hyprland/language")' "${WAYBAR_CONFIG}" >/dev/null 2>&1; then
  jq '."modules-right" += ["hyprland/language"] | . + {"hyprland/language": {"format": "{short}"}}' \
    "${WAYBAR_CONFIG}" >"${WAYBAR_CONFIG}.tmp" && mv "${WAYBAR_CONFIG}.tmp" "${WAYBAR_CONFIG}"
  omarchy-restart-waybar
fi

# Disable IDLE locking until the `hyprlock` bug is fixed upstream.
LINE="exec-once = while ! pgrep -x hypridle; do sleep 0.2; done && omarchy-toggle-idle"
grep -qF "$LINE" "${HOME}/.config/hypr/autostart.conf" 2>/dev/null || echo "$LINE" >>"${HOME}/.config/hypr/autostart.conf"

# Disable hardware rendered cursors to preven visual artifacts.
LINE="env = WLR_NO_HARDWARE_CURSORS,1"
grep -qF "$LINE" "${HOME}/.config/hypr/envs.conf" 2>/dev/null || echo "$LINE" >>"${HOME}/.config/hypr/envs.conf"

# Install AUR Packages.
applications=(
  jetbrains-toolbox
  lmstudio-bin
  slack-desktop
)
for application in "${applications[@]}"; do
  sudo yay -S --noconfirm --needed "${application}"
done
unset application
unset applications

# Install Web Applications
web_applications=(
  "Claude|https://claude.ai/new|https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/claude-ai-light.png"
  "Todoist|https://app.todoist.com/app/today|https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/todoist.png"
)
for web_application in "${web_applications[@]}"; do
  IFS='|' read -r name url icon <<<"${web_application}"
  omarchy-webapp-install "${name}" "${url}" "${icon}"
done
unset web_application
unset web_applications

# Enable SSH agent via systemd for passphrase caching.
systemctl --user enable --now ssh-agent.socket

# Set SSH_AUTH_SOCK for the SSH agent in Hyprland.
LINE='env = SSH_AUTH_SOCK,$XDG_RUNTIME_DIR/ssh-agent.socket'
grep -qF "$LINE" "${HOME}/.config/hypr/envs.conf" 2>/dev/null || echo "$LINE" >>"${HOME}/.config/hypr/envs.conf"

# Auto-add SSH keys to the agent on first use.
mkdir -p "${HOME}/.ssh" && chmod 700 "${HOME}/.ssh"
touch "${HOME}/.ssh/config" && chmod 600 "${HOME}/.ssh/config"
if ! grep -q "AddKeysToAgent" "${HOME}/.ssh/config"; then
  printf '\nHost *\n  AddKeysToAgent yes\n' >>"${HOME}/.ssh/config"
fi

# Source custom bash aliases.
ALIASES_SOURCE="source \"${DOTFILES_DIRECTORY}/arch/bash/aliases\""
grep -qF "${ALIASES_SOURCE}" "${HOME}/.bashrc" 2>/dev/null || echo "${ALIASES_SOURCE}" >>"${HOME}/.bashrc"

# Install lazygit configuration file.
mkdir -p "${HOME}/.config/lazygit"
ln -sf "${DOTFILES_DIRECTORY}/lazygit/config.yml" "${HOME}/.config/lazygit/config.yml"

# Show hidden files in NeoVim.
stow -d "${DOTFILES_DIRECTORY}/arch" -t "${HOME}" nvim

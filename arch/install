#!/bin/bash

# `-e` Exit on error.
# `-u` Treat unset variables as an error.
set -eu

# Determine the dotfiles directory.
DOTFILES_DIRECTORY="$(git rev-parse --show-toplevel)"

# Install Laravel development environment.
if [ -x "${HOME}/.local/share/omarchy/bin/omarchy-install-dev-env" ]; then
  "${HOME}/.local/share/omarchy/bin/omarchy-install-dev-env" laravel
fi

# Optimize resolution for my monitors.
if [ -f "${HOME}/.config/hypr/monitors.conf" ]; then
  sed -i \
    -e 's/^env = GDK_SCALE,2/# &/' \
    -e 's/^monitor=,preferred,auto,auto/# &/' \
    -e 's/^# env = GDK_SCALE,1$/env = GDK_SCALE,1/' \
    -e 's/^# monitor=,preferred,auto,1$/monitor=,preferred,auto,1/' \
    "${HOME}/.config/hypr/monitors.conf"
fi

# Allow to toggle between keyboard layouts.
if [ -f "${HOME}/.config/hypr/input.conf" ]; then
  sed -i \
    -e 's/^.*kb_layout.*/  kb_layout = us,es/' \
    -e 's/^\(.*kb_options = compose:caps\).*/\1,grp:alts_toggle/' \
    "${HOME}/.config/hypr/input.conf"
fi

# Show the active keyboard layout in waybar.
WAYBAR_CONFIG="${HOME}/.config/waybar/config.jsonc"
if ! jq -e '."modules-right" | index("hyprland/language")' "${WAYBAR_CONFIG}" >/dev/null 2>&1; then
  jq '."modules-right" += ["hyprland/language"] | . + {"hyprland/language": {"format": "{short}"}}' \
    "${WAYBAR_CONFIG}" >"${WAYBAR_CONFIG}.tmp" && mv "${WAYBAR_CONFIG}.tmp" "${WAYBAR_CONFIG}"
  omarchy-restart-waybar
fi

# Disable IDLE locking until the `hyprlock` bug is fixed upstream.
LINE="exec-once = while ! pgrep -x hypridle; do sleep 0.2; done && omarchy-toggle-idle"
grep -qF "$LINE" "${HOME}/.config/hypr/autostart.conf" 2>/dev/null || echo "$LINE" >>"${HOME}/.config/hypr/autostart.conf"

# Disable hardware rendered cursors to preven visual artifacts.
LINE="env = WLR_NO_HARDWARE_CURSORS,1"
grep -qF "$LINE" "${HOME}/.config/hypr/envs.conf" 2>/dev/null || echo "$LINE" >>"${HOME}/.config/hypr/envs.conf"

# Install AUR Packages.
applications=(
  jetbrains-toolbox
  lmstudio-bin
  slack-desktop
)
for application in "${applications[@]}"; do
  yay -S --noconfirm --needed "${application}"
done
unset application
unset applications

# Install the .NET SDK for C# development.
sudo pacman -S --noconfirm --needed dotnet-sdk

# Install Web Applications
web_applications=(
  "Claude|https://claude.ai/new|https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/claude-ai-light.png"
  "Todoist|https://app.todoist.com/app/today|https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/todoist.png"
)
for web_application in "${web_applications[@]}"; do
  IFS='|' read -r name url icon <<<"${web_application}"
  omarchy-webapp-install "${name}" "${url}" "${icon}"
done
unset web_application
unset web_applications

# Enable SSH daemon for incoming connections.
sudo systemctl enable --now sshd

# Enable SSH agent via systemd for passphrase caching.
systemctl --user enable --now ssh-agent.socket

# Set SSH_AUTH_SOCK for the SSH agent in Hyprland.
LINE='env = SSH_AUTH_SOCK,$XDG_RUNTIME_DIR/ssh-agent.socket'
grep -qF "$LINE" "${HOME}/.config/hypr/envs.conf" 2>/dev/null || echo "$LINE" >>"${HOME}/.config/hypr/envs.conf"

# Auto-add SSH keys to the agent on first use.
mkdir -p "${HOME}/.ssh" && chmod 700 "${HOME}/.ssh"
touch "${HOME}/.ssh/config" && chmod 600 "${HOME}/.ssh/config"
if ! grep -q "AddKeysToAgent" "${HOME}/.ssh/config"; then
  printf '\nHost *\n  AddKeysToAgent yes\n' >>"${HOME}/.ssh/config"
fi

# Source custom bash aliases.
ALIASES_SOURCE="source \"${DOTFILES_DIRECTORY}/arch/bash/aliases\""
grep -qF "${ALIASES_SOURCE}" "${HOME}/.bashrc" 2>/dev/null || echo "${ALIASES_SOURCE}" >>"${HOME}/.bashrc"

# Install stow for managing dotfile symlinks.
sudo pacman -S --noconfirm --needed stow

# Install lazygit configuration file.
stow -d "${DOTFILES_DIRECTORY}/arch" -t "${HOME}" lazygit

# Stow NeoVim configuration (hidden files, etc.).
stow -d "${DOTFILES_DIRECTORY}/arch" -t "${HOME}" nvim


# Gaming: install gamemode (auto-switches CPU to performance mode while gaming),
# mangohud (in-game FPS/frametime overlay), and python-vdf (to edit Steam config).
sudo pacman -S --noconfirm --needed gamemode lib32-gamemode mangohud lib32-mangohud python-vdf

# Gaming: Hyprland overrides for the 144Hz monitor.
# - allow_tearing: lets games skip vsync for lower input lag (per-game, see windowrules).
# - vrr: adaptive sync so the monitor matches the game's framerate instead of stuttering.
# - direct_scanout: disabled because multi-window games (like Doom Eternal's launcher)
#   cause the compositor to flicker between scanout and composited mode on NVIDIA.
LOOKNFEEL="${HOME}/.config/hypr/looknfeel.conf"
if [ -f "${LOOKNFEEL}" ]; then
  grep -q 'allow_tearing' "${LOOKNFEEL}" || cat >>"${LOOKNFEEL}" <<'GAMING'

general {
    allow_tearing = true
}

misc {
    vrr = 1
}

render {
    direct_scanout = false
}
GAMING
fi

# Gaming: window rules for Steam games.
# - immediate: enables tearing for lower input lag (requires allow_tearing above).
# - tag/opacity: removes Omarchy's default 0.97 transparency so games render at full opacity.
# - fullscreen for DOOMEternal: the game opens a launcher + game window side by side;
#   without this rule the game never goes fullscreen on its own.
HYPRLAND="${HOME}/.config/hypr/hyprland.conf"
if [ -f "${HYPRLAND}" ]; then
  LINE='windowrule = immediate on, match:class steam_app_'
  grep -qF "${LINE}" "${HYPRLAND}" || echo "${LINE}" >>"${HYPRLAND}"
  LINE='windowrule = tag -default-opacity, match:class steam_app_'
  grep -qF "${LINE}" "${HYPRLAND}" || echo "${LINE}" >>"${HYPRLAND}"
  LINE='windowrule = opacity 1.0 1.0, match:class steam_app_'
  grep -qF "${LINE}" "${HYPRLAND}" || echo "${LINE}" >>"${HYPRLAND}"
  LINE='windowrule = fullscreen on, match:title DOOMEternal'
  grep -qF "${LINE}" "${HYPRLAND}" || echo "${LINE}" >>"${HYPRLAND}"
fi

# Gaming: NVIDIA environment variables.
# - GBM_BACKEND: required for Wayland compositing on NVIDIA.
# - GL_GSYNC/VRR_ALLOWED: enables adaptive sync at the driver level (works with vrr above).
# - OGL_DEDICATED_HW_STATE: prevents OpenGL state corruption across application contexts.
# - GLX_VENDOR_LIBRARY_NAME: ensures GLX applications use the NVIDIA driver, not Mesa.
# - LIBVA/NVD: enables hardware video decoding through the NVIDIA driver.
ENVS="${HOME}/.config/hypr/envs.conf"
if [ -f "${ENVS}" ]; then
  grep -qF 'GBM_BACKEND' "${ENVS}" || echo 'env = GBM_BACKEND,nvidia-drm' >>"${ENVS}"
  grep -qF '__GL_GSYNC_ALLOWED' "${ENVS}" || echo 'env = __GL_GSYNC_ALLOWED,1' >>"${ENVS}"
  grep -qF '__GL_VRR_ALLOWED' "${ENVS}" || echo 'env = __GL_VRR_ALLOWED,1' >>"${ENVS}"
  grep -qF 'OGL_DEDICATED_HW_STATE_PER_CONTEXT' "${ENVS}" || echo 'env = OGL_DEDICATED_HW_STATE_PER_CONTEXT,ENABLE_ROBUST' >>"${ENVS}"
  grep -qF '__GLX_VENDOR_LIBRARY_NAME' "${ENVS}" || echo 'env = __GLX_VENDOR_LIBRARY_NAME,nvidia' >>"${ENVS}"
  grep -qF 'LIBVA_DRIVER_NAME' "${ENVS}" || echo 'env = LIBVA_DRIVER_NAME,nvidia' >>"${ENVS}"
  grep -qF 'NVD_BACKEND' "${ENVS}" || echo 'env = NVD_BACKEND,direct' >>"${ENVS}"
fi

# Gaming: set "gamemoderun mangohud %command%" as launch options for all Steam games.
# gamemoderun auto-switches CPU governor to performance mode while a game is running.
# mangohud shows an in-game FPS/frametime overlay to monitor performance.
"${DOTFILES_DIRECTORY}/arch/steam-launch-options"

# Gaming: keep the GPU driver loaded between game sessions so each launch doesn't
# pay the full driver initialization cost.
sudo systemctl enable --now nvidia-persistenced

# Gaming: with 64 GB of RAM, the default swappiness of 60 is too aggressive — the kernel
# moves game data to the SSD unnecessarily. A value of 10 keeps everything in memory.
sudo tee /etc/sysctl.d/99-gaming.conf >/dev/null <<'SYSCTL'
vm.swappiness=10
SYSCTL
sudo sysctl --system >/dev/null

LAZYVIM_JSON="${HOME}/.config/nvim/lazyvim.json"
if [ -f "${LAZYVIM_JSON}" ]; then
  jq '.extras |= (. + [
    "lazyvim.plugins.extras.dap.core",
    "lazyvim.plugins.extras.lang.dotnet",
    "lazyvim.plugins.extras.lang.php",
    "lazyvim.plugins.extras.lang.typescript",
    "lazyvim.plugins.extras.lang.vue",
    "lazyvim.plugins.extras.formatting.prettier",
    "lazyvim.plugins.extras.linting.eslint"
  ] | unique)' "${LAZYVIM_JSON}" > "${LAZYVIM_JSON}.tmp" && mv "${LAZYVIM_JSON}.tmp" "${LAZYVIM_JSON}"
fi

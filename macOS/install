#!/bin/bash

# `-e` Exit on error.
# `-u` Trait unset variables as an error.
# `-o pipeline` Propagate pipeline errors.
set -euo pipefail

# Install command line tools.
if ! xcode-select -p &>/dev/null; then
  xcode-select --install
  echo "Waiting for Command Line Tools installation..."
  until xcode-select -p &>/dev/null; do sleep 5; done
fi

# Install oh-my-zsh.
if [ ! -d "${HOME}/.oh-my-zsh" ]; then
  git clone https://github.com/ohmyzsh/ohmyzsh.git "${HOME}/.oh-my-zsh"
fi

# Determine the dotfiles directory.
DOTFILES_DIRECTORY="$(git rev-parse --show-toplevel)"

# Install SSH related files
mkdir -p "${HOME}/.ssh/projects"
stow -d "${DOTFILES_DIRECTORY}/macOS" -t "${HOME}" ssh

# Install ZSH configuration files.
stow -d "${DOTFILES_DIRECTORY}/macOS" -t "${HOME}" zsh

# Install git configuration files.
mkdir -p "${HOME}/.config/git"
if [ ! -f "${HOME}/.config/git/local.gitconfig" ]; then
  cp "${DOTFILES_DIRECTORY}/git/local.gitconfig" "${HOME}/.config/git/local.gitconfig"
fi
stow -d "${DOTFILES_DIRECTORY}" -t "${HOME}" git

# Install python's startup commands.
stow -d "${DOTFILES_DIRECTORY}/macOS" -t "${HOME}" python

# Suppress login messages.
touch "${HOME}/.hushlogin"

# Install Brew.
if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

touch ~/.zprofile
grep -qF 'eval "$(/opt/homebrew/bin/brew shellenv)"' ~/.zprofile \
  || echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >>~/.zprofile
eval "$(/opt/homebrew/bin/brew shellenv)"

# Install applications through Brew.
brew bundle install --file="${DOTFILES_DIRECTORY}/macOS/brew/Brewfile"

# Install lazygit configuration file.
mkdir -p "${HOME}/Library/Application Support/lazygit"
ln -sf "${DOTFILES_DIRECTORY}/lazygit/config.yml" "${HOME}/Library/Application Support/lazygit/config.yml"

# Remove the need for `sudo` while installing node packages globally.
mkdir -p "${HOME}/.npm-packages"
npm config set prefix "${HOME}/.npm-packages"

# Install tmux configuration file.
stow -d "${DOTFILES_DIRECTORY}/macOS" -t "${HOME}" tmux
if tmux info &>/dev/null; then
  tmux source "${HOME}/.tmux.conf"
fi

# Install Vim configuration.
stow -d "${DOTFILES_DIRECTORY}/macOS" -t "${HOME}" vim

# Install NeoVim with LazyVim starter.
if [ ! -d "${HOME}/.config/nvim" ]; then
  git clone https://github.com/LazyVim/starter "${HOME}/.config/nvim"
  rm -rf "${HOME}/.config/nvim/.git"
fi
stow -d "${DOTFILES_DIRECTORY}/macOS" -t "${HOME}" nvim

# Configure NeoVim for PHP development with intelephense.
NVIM_OPTIONS="${HOME}/.config/nvim/lua/config/options.lua"
grep -qF 'lazyvim_php_lsp' "${NVIM_OPTIONS}" 2>/dev/null || echo 'vim.g.lazyvim_php_lsp = "intelephense"' >> "${NVIM_OPTIONS}"
grep -qF 'relativenumber' "${NVIM_OPTIONS}" 2>/dev/null || echo 'vim.opt.relativenumber = false' >> "${NVIM_OPTIONS}"
grep -qF 'autoformat' "${NVIM_OPTIONS}" 2>/dev/null || echo 'vim.g.autoformat = false' >> "${NVIM_OPTIONS}"

LAZYVIM_JSON="${HOME}/.config/nvim/lazyvim.json"
if [ -f "${LAZYVIM_JSON}" ]; then
  jq '
    .extras |= (
      if index("lazyvim.plugins.extras.lang.php") then . else . + ["lazyvim.plugins.extras.lang.php"] end |
      if index("lazyvim.plugins.extras.lang.typescript") then . else . + ["lazyvim.plugins.extras.lang.typescript"] end |
      if index("lazyvim.plugins.extras.lang.vue") then . else . + ["lazyvim.plugins.extras.lang.vue"] end |
      if index("lazyvim.plugins.extras.formatting.prettier") then . else . + ["lazyvim.plugins.extras.formatting.prettier"] end |
      if index("lazyvim.plugins.extras.linting.eslint") then . else . + ["lazyvim.plugins.extras.linting.eslint"] end
    )
  ' "${LAZYVIM_JSON}" > "${LAZYVIM_JSON}.tmp" && mv "${LAZYVIM_JSON}.tmp" "${LAZYVIM_JSON}"
fi

# Install PHP's XDebug extension.
if ! php -m 2>/dev/null | grep -qi xdebug; then
  pecl install xdebug
fi

# Update macOS defaults.
source "${DOTFILES_DIRECTORY}/macOS/defaults"
